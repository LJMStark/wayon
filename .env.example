# Copy to .env.local and fill in values. DO NOT commit .env.local.

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-03
SANITY_API_TOKEN=

# Resend — inquiry email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=
INQUIRY_NOTIFY_TO=

# Public deployment origin
NEXT_PUBLIC_SITE_URL=https://www.zylsinteredstone.com

# Analytics (all optional; scripts are gated on presence)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_BAIDU_TONGJI_ID=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Sanity draft / preview mode
SANITY_PREVIEW_SECRET=
