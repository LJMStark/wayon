# Copy to .env.local and fill in values. DO NOT commit .env.local.

# Payload CMS
PAYLOAD_SECRET=
DATABASE_URL=

# Cloudflare R2 media storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Public deployment origin
NEXT_PUBLIC_SITE_URL=https://www.zylsinteredstone.com

# AI product copy generation (server-side script only)
OPENAI_API_KEY=
